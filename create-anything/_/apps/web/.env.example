# ============================================================
# SWIPE HOME — environment variables
# Copy this to .env and fill in your values.
# In Vercel: add each one under Project > Settings > Environment Variables
# ============================================================

# ------ Supabase ------
# Get from: Supabase Dashboard > Project Settings > API

# Exposed to the browser (safe — anon key only)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Server-side only (never expose to the browser)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ------ Database ------
# Get from: Supabase Dashboard > Project Settings > Database > Connection string
# Use the "Transaction" pooler URL (port 6543) for Vercel serverless functions
# Format: postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres

# ------ OpenAI (Task 3) ------
OPENAI_API_KEY=sk-...

# ------ App ------
# Your production URL (used for auth redirects, CORS)
APP_URL=https://swip3home.com
